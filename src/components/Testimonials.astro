---
// Testimonials.astro - Customer reviews and ratings
const testimonials = [
  {
    name: "Esteban Rossi",
    role: "Cliente desde 2021",
    rating: "5.0",
    text: "Excelente atención y el lugar tiene un estilo impecable. El ritual de la toalla caliente con el perfilado de barba es espectacular, realmente se toman el tiempo para hacer un trabajo perfecto.",
  },
  {
    name: "Lucas Benítez",
    role: "Cliente Regular",
    rating: "5.0",
    text: "La mejor barbería de Buenos Aires sin dudas. No solo el corte es perfecto, sino que la ambientación, la música de jazz de fondo y el whisky de cortesía te hacen sentir en un club exclusivo.",
  },
  {
    name: "Mariano Soria",
    role: "Cliente Nuevo",
    rating: "5.0",
    text: "Fui por primera vez recomendado por un amigo y me atendió Lautaro. El servicio de visagismo fue excelente, me recomendó un corte que le va genial a mi rostro. Ya tengo mi reserva para el próximo mes.",
  }
];
---

<section id="testimonials" class="relative py-24 bg-wood-950 overflow-hidden border-t border-wood-900/10">
  <!-- Glowing gradient background elements -->
  <div class="absolute top-12 left-1/2 -translate-x-1/2 w-96 h-96 bg-gold-600/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-width-container mx-auto px-6 relative z-10 w-full">
    <!-- Section Title -->
    <div class="text-center max-w-2xl mx-auto space-y-3 mb-16">
      <span class="text-xs tracking-[0.25em] text-gold-500 font-bold uppercase block">Clientes Satisfechos</span>
      <h2 class="font-serif text-3xl sm:text-4xl font-bold tracking-tight text-wood-50">
        ¿Qué Dicen de El Roble?
      </h2>
      <p class="text-xs sm:text-sm text-wood-300 font-light leading-relaxed">
        Nuestros clientes son caballeros que aprecian el valor de un buen servicio y la consistencia en el diseño.
      </p>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
      {testimonials.map((testimonial) => (
        <div class="p-8 bg-wood-900/20 border border-wood-900/50 rounded-xl hover:border-gold-500/20 transition-all duration-300 hover:shadow-xl hover:shadow-gold-500/[0.01] flex flex-col justify-between group">
          <div class="space-y-6">
            <!-- Stars & Quote -->
            <div class="flex items-center justify-between">
              <!-- Star rating bar -->
              <div class="flex items-center space-x-1">
                {[...Array(5)].map(() => (
                  <svg class="w-4 h-4 text-gold-500 fill-current" viewBox="0 0 24 24">
                    <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
                  </svg>
                ))}
              </div>
              <!-- Elegant double quotes -->
              <svg class="w-8 h-8 text-gold-500/10" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.988zm-12 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
              </svg>
            </div>

            <p class="text-xs sm:text-sm text-wood-200 font-light leading-relaxed italic">
              "{testimonial.text}"
            </p>
          </div>

          <div class="pt-6 border-t border-wood-800/20 mt-6 flex flex-col">
            <span class="font-serif text-sm font-bold text-wood-50">{testimonial.name}</span>
            <span class="text-[10px] text-wood-400 font-semibold tracking-wider uppercase mt-0.5">{testimonial.role}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
