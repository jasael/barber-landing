---
// Hero.astro - Premium minimalist Hero section with dark amaderado accents
---

<section id="hero" class="relative min-h-[90vh] flex items-center justify-center pt-12 pb-24 overflow-hidden bg-wood-950">
  <!-- Subtle wood texture background overlay -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(156,98,59,0.1),transparent_50%)]"></div>
  <div class="absolute -bottom-48 -left-48 w-96 h-96 bg-gold-600/5 rounded-full blur-[120px]"></div>

  <div class="max-width-container mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center relative z-10 w-full">
    <!-- Left Copy Column -->
    <div class="lg:col-span-7 flex flex-col space-y-8 animate-fade-in-up">
      <div class="inline-flex items-center space-x-2 px-3 py-1 bg-wood-900/60 border border-gold-500/20 rounded-full w-fit">
        <span class="w-1.5 h-1.5 bg-gold-400 rounded-full animate-pulse"></span>
        <span class="text-[10px] tracking-widest text-gold-400 font-bold uppercase">Abierto de Martes a Sábado</span>
      </div>

      <div class="space-y-4">
        <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-wood-50 leading-none">
          Estilo y Tradición <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-gold-400 via-gold-500 to-wood-300">
            en Madera y Acero
          </span>
        </h1>
        <p class="text-sm sm:text-base text-wood-200 font-light max-w-xl leading-relaxed">
          En El Roble entendemos que el corte no es solo una rutina; es un ritual. Fusionamos técnicas clásicas de barbería tradicional con el diseño moderno, rodeado de un entorno sofisticado con aroma a cedro, whisky y toallas calientes.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 pt-4">
        <a
          href="#booking"
          id="hero-booking-btn"
          class="inline-flex items-center justify-center px-8 py-4 font-semibold text-xs tracking-widest text-wood-950 uppercase bg-gold-500 rounded shadow-lg shadow-gold-500/10 hover:shadow-gold-500/20 transition-all duration-300 hover:bg-gold-400 active:scale-95 text-center"
        >
          Reservar Turno
        </a>
        <a
          href="#services"
          class="inline-flex items-center justify-center px-8 py-4 font-semibold text-xs tracking-widest text-wood-100 uppercase border border-wood-700 rounded hover:border-gold-500/50 hover:bg-wood-900/20 transition-all duration-300 active:scale-95 text-center"
        >
          Explorar Servicios
        </a>
      </div>

      <!-- Quick Metrics -->
      <div class="grid grid-cols-3 gap-6 pt-8 border-t border-wood-900/40">
        <div>
          <p class="font-serif text-2xl font-bold text-gold-400">15+</p>
          <p class="text-[10px] tracking-wider text-wood-300 uppercase font-medium">Años de Exp.</p>
        </div>
        <div>
          <p class="font-serif text-2xl font-bold text-gold-400">10k+</p>
          <p class="text-[10px] tracking-wider text-wood-300 uppercase font-medium">Barbas Talladas</p>
        </div>
        <div>
          <p class="font-serif text-2xl font-bold text-gold-400">4.9★</p>
          <p class="text-[10px] tracking-wider text-wood-300 uppercase font-medium">Opiniones de Google</p>
        </div>
      </div>
    </div>

    <!-- Right Image Column -->
    <div class="lg:col-span-5 relative w-full flex items-center justify-center">
      <!-- Outer gold frame shape vector -->
      <div class="absolute -inset-1.5 border border-gold-500/20 rounded-xl clip-diagonal pointer-events-none"></div>
      <div class="absolute -inset-3 border border-wood-700/10 rounded-2xl pointer-events-none"></div>
      
      <!-- Premium local image frame -->
      <div class="relative w-full aspect-square rounded-lg overflow-hidden border border-gold-500/30 shadow-2xl transition-all duration-500 hover:border-gold-400 group">
        <!-- Overlay layer to blend colors -->
        <div class="absolute inset-0 bg-gradient-to-t from-wood-950 via-transparent to-transparent opacity-40 mix-blend-multiply z-10"></div>
        <img
          src="/images/hero-barber-interior.png"
          alt="El Roble Barbershop premium interior view"
          class="w-full h-full object-cover transform scale-100 group-hover:scale-105 transition-transform duration-700 ease-out"
        />
        <!-- Inner shadow framing -->
        <div class="absolute inset-0 ring-1 ring-inset ring-black/40 pointer-events-none"></div>
      </div>
    </div>
  </div>
</section>
