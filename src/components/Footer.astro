---
// Footer.astro - Semantic responsive footer with legal routes
---

<footer class="bg-wood-950 border-t border-wood-900/40 relative overflow-hidden">
  <div class="max-width-container mx-auto px-6 py-16 relative z-10 w-full">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 pb-12 border-b border-wood-900/20">
      <!-- Col 1: Branding -->
      <div class="md:col-span-5 flex flex-col space-y-4">
        <a href="/" class="flex items-center space-x-2 group w-fit">
          <div class="w-8 h-8 flex items-center justify-center bg-wood-900/60 border border-gold-500/30 rounded-lg overflow-hidden transition-all duration-300">
            <svg class="w-5 h-5 text-gold-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5l2 2h3a2 2 0 012 2v12a2 2 0 01-2 2z" />
            </svg>
          </div>
          <div class="flex flex-col">
            <span class="font-serif text-base font-bold tracking-widest text-wood-100 uppercase">EL ROBLE</span>
            <span class="text-[9px] tracking-[0.25em] text-gold-500 font-semibold uppercase">Barbershop</span>
          </div>
        </a>
        <p class="text-xs text-wood-300 font-light max-w-sm leading-relaxed">
          Un club de caballeros clásico con visión moderna en Palermo Soho. Tallamos tu mejor versión con precisión artesanal.
        </p>
      </div>

      <!-- Col 2: Navigation Links -->
      <div class="md:col-span-3 flex flex-col space-y-4">
        <h4 class="text-[10px] tracking-widest text-gold-500 font-bold uppercase">Navegación</h4>
        <ul class="space-y-2 text-xs text-wood-200 font-light">
          <li><a href="#hero" class="hover:text-gold-400 transition-colors">Inicio</a></li>
          <li><a href="#about" class="hover:text-gold-400 transition-colors">Sobre Nosotros</a></li>
          <li><a href="#services" class="hover:text-gold-400 transition-colors">Servicios</a></li>
          <li><a href="#testimonials" class="hover:text-gold-400 transition-colors">Opiniones</a></li>
          <li><a href="#booking" class="hover:text-gold-400 transition-colors">Contacto</a></li>
        </ul>
      </div>

      <!-- Col 3: Social & Compliance Links -->
      <div class="md:col-span-4 flex flex-col space-y-4">
        <h4 class="text-[10px] tracking-widest text-gold-500 font-bold uppercase">Redes y Legal</h4>
        <ul class="space-y-2 text-xs text-wood-200 font-light">
          <li><a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="hover:text-gold-400 transition-colors">Instagram</a></li>
          <li><a href="https://facebook.com" target="_blank" rel="noopener noreferrer" class="hover:text-gold-400 transition-colors">Facebook</a></li>
          <li><a href="/privacy" id="link-privacy" class="hover:text-gold-400 transition-colors font-medium">Política de Privacidad</a></li>
          <li><a href="/terms" id="link-terms" class="hover:text-gold-400 transition-colors font-medium">Términos del Servicio</a></li>
          <li><a href="/cancellation" id="link-cancellation" class="hover:text-gold-400 transition-colors font-medium">Política de Cancelación</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom copyrights and standard mentions -->
    <div class="flex flex-col sm:flex-row items-center justify-between pt-8 text-[11px] text-wood-400 font-light">
      <p>&copy; {new Date().getFullYear()} El Roble Barbershop. Todos los derechos reservados.</p>
      <p class="mt-2 sm:mt-0">
        <span>Tallado con precisión artesanal</span>
      </p>
    </div>
  </div>
</section>
