---
// Header.astro - Sticky responsive navbar with premium wooden/dark accents
---

<header class="sticky top-0 z-50 bg-wood-950/80 backdrop-blur-md border-b border-wood-900/40 transition-all duration-300">
  <div class="max-width-container mx-auto px-6 h-20 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center space-x-2 group">
      <div class="relative w-10 h-10 flex items-center justify-center bg-wood-900/60 border border-gold-500/30 rounded-lg overflow-hidden transition-all duration-300 group-hover:border-gold-500">
        <!-- SVG Icon - Shaving razor blade inspired line art -->
        <svg class="w-6 h-6 text-gold-400 transition-transform duration-500 group-hover:rotate-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5l2 2h3a2 2 0 012 2v12a2 2 0 01-2 2z" />
        </svg>
      </div>
      <div class="flex flex-col">
        <span class="font-serif text-lg font-bold tracking-widest text-wood-100 uppercase transition-colors group-hover:text-gold-400">EL ROBLE</span>
        <span class="text-[10px] tracking-[0.25em] text-gold-500 font-semibold uppercase">Barbershop</span>
      </div>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center space-x-8">
      <a href="#hero" class="text-xs tracking-widest text-wood-200 hover:text-gold-400 uppercase font-semibold transition-colors">Inicio</a>
      <a href="#about" class="text-xs tracking-widest text-wood-200 hover:text-gold-400 uppercase font-semibold transition-colors">Sobre Nosotros</a>
      <a href="#services" class="text-xs tracking-widest text-wood-200 hover:text-gold-400 uppercase font-semibold transition-colors">Servicios</a>
      <a href="#gallery" class="text-xs tracking-widest text-wood-200 hover:text-gold-400 uppercase font-semibold transition-colors">Galería</a>
      <a href="#testimonials" class="text-xs tracking-widest text-wood-200 hover:text-gold-400 uppercase font-semibold transition-colors">Opiniones</a>
      <a href="#booking" class="text-xs tracking-widest text-wood-200 hover:text-gold-400 uppercase font-semibold transition-colors">Contacto</a>
    </nav>

    <!-- Call to Action (Desktop) -->
    <div class="hidden md:block">
      <a href="#booking" id="nav-booking-btn" class="relative inline-flex items-center justify-center px-6 py-2.5 overflow-hidden font-semibold text-xs tracking-widest text-wood-950 uppercase bg-gold-500 rounded transition-all duration-300 hover:bg-gold-400 active:scale-95 group">
        Reservar Turno
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="md:hidden flex flex-col justify-between w-6 h-4 text-wood-200 hover:text-gold-400 focus:outline-none transition-colors" aria-label="Toggle Menu">
      <span class="w-full h-0.5 bg-current rounded-full transition-all duration-300 origin-left burger-line-1"></span>
      <span class="w-full h-0.5 bg-current rounded-full transition-all duration-300 burger-line-2"></span>
      <span class="w-full h-0.5 bg-current rounded-full transition-all duration-300 origin-left burger-line-3"></span>
    </button>
  </div>

  <!-- Mobile Dropdown Navigation -->
  <div id="mobile-nav" class="hidden md:hidden absolute top-20 left-0 w-full bg-wood-950/95 border-b border-wood-900/60 backdrop-blur-lg transform transition-all duration-300 origin-top scale-y-0 opacity-0 px-6 py-8 flex flex-col space-y-6">
    <a href="#hero" class="mobile-nav-link text-sm tracking-widest text-wood-200 hover:text-gold-400 uppercase font-semibold transition-colors">Inicio</a>
    <a href="#about" class="mobile-nav-link text-sm tracking-widest text-wood-200 hover:text-gold-400 uppercase font-semibold transition-colors">Sobre Nosotros</a>
    <a href="#services" class="mobile-nav-link text-sm tracking-widest text-wood-200 hover:text-gold-400 uppercase font-semibold transition-colors">Servicios</a>
    <a href="#gallery" class="mobile-nav-link text-sm tracking-widest text-wood-200 hover:text-gold-400 uppercase font-semibold transition-colors">Galería</a>
    <a href="#testimonials" class="mobile-nav-link text-sm tracking-widest text-wood-200 hover:text-gold-400 uppercase font-semibold transition-colors">Opiniones</a>
    <a href="#booking" class="mobile-nav-link text-sm tracking-widest text-wood-200 hover:text-gold-400 uppercase font-semibold transition-colors">Contacto</a>
    <a href="#booking" id="mobile-nav-booking-btn" class="mobile-nav-link w-full text-center py-3 font-semibold text-xs tracking-widest text-wood-950 uppercase bg-gold-500 rounded transition-colors hover:bg-gold-400">Reservar Turno</a>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileNav = document.getElementById('mobile-nav');
  const line1 = document.querySelector('.burger-line-1');
  const line2 = document.querySelector('.burger-line-2');
  const line3 = document.querySelector('.burger-line-3');
  const navLinks = document.querySelectorAll('.mobile-nav-link');

  function toggleMenu() {
    const isExpanded = mobileNav?.classList.contains('hidden');
    
    if (isExpanded) {
      mobileNav?.classList.remove('hidden');
      setTimeout(() => {
        mobileNav?.classList.add('scale-y-100', 'opacity-100');
      }, 10);
      
      // Transform burger lines to 'X'
      line1?.classList.add('rotate-45', 'translate-x-[2px]', 'translate-y-[-1px]');
      line2?.classList.add('opacity-0', 'scale-x-0');
      line3?.classList.add('-rotate-45', 'translate-x-[2px]', 'translate-y-[1px]');
    } else {
      mobileNav?.classList.remove('scale-y-100', 'opacity-100');
      // Reset lines
      line1?.classList.remove('rotate-45', 'translate-x-[2px]', 'translate-y-[-1px]');
      line2?.classList.remove('opacity-0', 'scale-x-0');
      line3?.classList.remove('-rotate-45', 'translate-x-[2px]', 'translate-y-[1px]');
      
      setTimeout(() => {
        mobileNav?.classList.add('hidden');
      }, 300);
    }
  }

  menuBtn?.addEventListener('click', toggleMenu);

  navLinks.forEach(link => {
    link.addEventListener('click', () => {
      mobileNav?.classList.remove('scale-y-100', 'opacity-100');
      line1?.classList.remove('rotate-45', 'translate-x-[2px]', 'translate-y-[-1px]');
      line2?.classList.remove('opacity-0', 'scale-x-0');
      line3?.classList.remove('-rotate-45', 'translate-x-[2px]', 'translate-y-[1px]');
      
      setTimeout(() => {
        mobileNav?.classList.add('hidden');
      }, 300);
    });
  });
</script>
