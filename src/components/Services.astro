---
// Services.astro - Price lists & Grooming services grid
const services = [
  {
    id: "service-haircut",
    name: "Corte de Cabello Real",
    price: "$4.500",
    time: "45 min",
    description: "Asesoramiento de visagismo, corte clásico o degradado moderno, lavado premium con shampoo de ortiga y styling final.",
  },
  {
    id: "service-beard",
    name: "Perfilado de Barba y Spa",
    price: "$3.500",
    time: "35 min",
    description: "Diseño y rebaje de barba con tijera y máquina, afeitado de contornos a navaja, toalla caliente aromática y aceites hidratantes.",
  },
  {
    id: "service-combo",
    name: "Combo Roble Imperial",
    price: "$7.000",
    time: "75 min",
    description: "Corte de autor + ritual completo de perfilado de barba con toalla caliente, masaje capilar y degustación de whisky de cortesía.",
  },
  {
    id: "service-shave",
    name: "Afeitado Tradicional",
    price: "$3.200",
    time: "40 min",
    description: "Ritual clásico con jabón artesanal batido en taza de cobre, brocha de pelo de tejón, doble toalla caliente, navaja barbera y bálsamo.",
  }
];
---

<section id="services" class="relative py-24 bg-wood-900/10 border-t border-wood-900/20">
  <div class="absolute inset-x-0 bottom-0 h-1/3 bg-[radial-gradient(circle_at_bottom_right,rgba(156,98,59,0.03),transparent_60%)] pointer-events-none"></div>

  <div class="max-width-container mx-auto px-6 relative z-10 w-full">
    <!-- Section Title -->
    <div class="text-center max-w-2xl mx-auto space-y-3 mb-16">
      <span class="text-xs tracking-[0.25em] text-gold-500 font-bold uppercase block">El Ritual</span>
      <h2 class="font-serif text-3xl sm:text-4xl font-bold tracking-tight text-wood-50">
        Nuestros Servicios de Grooming
      </h2>
      <p class="text-xs sm:text-sm text-wood-300 font-light leading-relaxed">
        Cada uno de nuestros servicios incluye diagnóstico personalizado, lavado prémium y toallas aromáticas. Reservá para experimentar el verdadero arte.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
      {services.map((service) => (
        <div
          id={service.id}
          class="relative p-8 bg-wood-900/30 border border-wood-800/40 rounded-xl hover:border-gold-500/40 transition-all duration-300 hover:shadow-xl hover:shadow-gold-500/[0.02] flex flex-col justify-between group"
        >
          <!-- Corner decorative lines -->
          <span class="absolute top-0 right-0 w-8 h-px bg-gold-500/0 group-hover:bg-gold-500/40 transition-all duration-500"></span>
          <span class="absolute top-0 right-0 h-8 w-px bg-gold-500/0 group-hover:bg-gold-500/40 transition-all duration-500"></span>

          <div class="space-y-4">
            <div class="flex items-start justify-between">
              <h3 class="font-serif text-xl font-bold text-wood-50 group-hover:text-gold-400 transition-colors duration-300">
                {service.name}
              </h3>
              <div class="flex flex-col items-end">
                <span class="font-serif text-xl font-extrabold text-gold-500">{service.price}</span>
                <span class="text-[10px] text-wood-400 tracking-wider font-semibold uppercase">{service.time}</span>
              </div>
            </div>
            <p class="text-xs sm:text-sm text-wood-200 font-light leading-relaxed">
              {service.description}
            </p>
          </div>

          <div class="pt-6 border-t border-wood-800/30 mt-6 flex items-center justify-between">
            <span class="text-[10px] tracking-widest text-wood-400 uppercase font-medium">Incluye lavado prémium</span>
            <a
              href="#booking"
              class="text-xs tracking-widest text-gold-500 hover:text-gold-400 font-bold uppercase transition-colors flex items-center space-x-1.5"
            >
              <span>Reservar</span>
              <svg class="w-3.5 h-3.5 transform transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
