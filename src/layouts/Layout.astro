---
// Layout.astro - Global premium theme frame for El Roble Barbershop
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "El Roble Barbershop | Barbería Premium en Palermo Soho",
  description = "Club de caballeros clásico y moderno en Palermo Soho. Cortes de autor, perfilado de barba con toalla caliente, rituales clásicos y un ambiente excepcional."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="h-full scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://elroblebarberia.com" />

    <!-- OpenGraph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/images/hero-barber-interior.png" />
    <meta property="og:url" content="https://elroblebarberia.com" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/images/hero-barber-interior.png" />

    <!-- Google Fonts Imports -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,600;0,700;0,800;1,600&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-wood-950 text-wood-100 min-h-full flex flex-col justify-between selection:bg-gold-500 selection:text-wood-950 overflow-x-hidden">
    <!-- Skip to main content for accessibility -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-gold-500 text-wood-950 px-4 py-2 rounded font-semibold text-xs tracking-wider z-[100]">
      Saltar al contenido principal
    </a>

    <slot name="header" />

    <main id="main-content" class="flex-grow">
      <slot />
    </main>

    <slot name="footer" />
  </body>
</html>
